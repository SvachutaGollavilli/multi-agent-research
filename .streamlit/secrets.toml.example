# .streamlit/secrets.toml.example
# -----------------------------------------------------------------
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml -- it is in .gitignore.
#
# On Streamlit Community Cloud:
#   App settings -> Secrets -> paste the key=value pairs below.
# -----------------------------------------------------------------

ANTHROPIC_API_KEY = "sk-ant-..."
TAVILY_API_KEY    = "tvly-..."

# Optional: replace the default SQLite file with a hosted Postgres DB.
# Leave commented out to use the default SQLite file (data/pipeline.db).
# DATABASE_URL = "postgresql://user:password@host:5432/dbname"
